LABEL org.opencontainers.image.source="https://example.com/__BELUGA_PROJECT_NAME__"
LABEL org.opencontainers.image.version="__BELUGA_VERSION__"
LABEL org.opencontainers.image.title="__BELUGA_PROJECT_NAME__"

USER nonroot:nonroot
COPY --from=builder /out/__BELUGA_PROJECT_NAME__ /__BELUGA_PROJECT_NAME__
ENTRYPOINT ["/__BELUGA_PROJECT_NAME__"]
