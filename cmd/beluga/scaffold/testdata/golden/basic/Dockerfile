# syntax=docker/dockerfile:1.7
# Multi-stage Dockerfile for sample.
# Generated by `beluga init` on 2026-04-20T00:00:00Z.

FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/sample .

# NOTE: this image requires CGO_ENABLED=0. If you add a package with CGo
# requirements, switch to gcr.io/distroless/base-debian12 or a glibc-based
# runtime image.
FROM gcr.io/distroless/static-debian12:nonroot

LABEL org.opencontainers.image.source="https://example.com/sample"
LABEL org.opencontainers.image.version="v2.10.1"
LABEL org.opencontainers.image.title="sample"

USER nonroot:nonroot
COPY --from=builder /out/sample /sample
ENTRYPOINT ["/sample"]
