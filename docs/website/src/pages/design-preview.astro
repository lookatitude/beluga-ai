---
/**
 * /design-preview — Phase 2 checkpoint page.
 *
 * NOT public. Not linked from the nav. This page exists so the
 * tokens, typography, and shared primitives (EditorialSection,
 * CodeProof) can be reviewed side-by-side before any marketing
 * page is rebuilt.
 *
 * Delete this file once Phase 3 (marketing rebuild) lands.
 */
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import EditorialSection from "@/components/marketing/EditorialSection.astro";
import CodeProof from "@/components/marketing/CodeProof.astro";

const heroCode = `package main

import (
    "context"
    "fmt"

    _ "github.com/lookatitude/beluga-ai/llm/providers/anthropic"
    "github.com/lookatitude/beluga-ai/llm"
    "github.com/lookatitude/beluga-ai/schema"
)

func main() {
    model, err := llm.New("anthropic", llm.Config{Model: "claude-sonnet-4-6"})
    if err != nil {
        panic(err)
    }

    stream, err := model.Stream(context.Background(), []schema.Message{
        {Role: schema.RoleUser, Content: "explain iter.Seq2 in one sentence"},
    })
    if err != nil {
        panic(err)
    }

    for chunk, err := range stream.Range {
        if err != nil {
            panic(err)
        }
        fmt.Print(chunk.Content)
    }
}`;

const middlewareCode = `// Circuit breaker, retry, and OTel are middleware on the same
// interface as your LLM call — no special infrastructure required.
model := llm.ApplyMiddleware(base,
    llm.WithGuardrails(guardPipeline),
    llm.WithTracing(),
    llm.WithRateLimit(rpm, tpm),
    llm.WithRetry(3),
)`;

const providerCode = `// One import, fully wired. Every provider registers in init().
import (
    _ "github.com/lookatitude/beluga-ai/llm/providers/anthropic"
    _ "github.com/lookatitude/beluga-ai/rag/vectorstore/providers/pgvector"
    _ "github.com/lookatitude/beluga-ai/voice/stt/providers/deepgram"
    _ "github.com/lookatitude/beluga-ai/workflow/providers/temporal"
)`;
---

<MarketingLayout
  title="Design preview"
  description="Internal design review page — Phase 2 tokens and primitives"
  robots="noindex, nofollow"
>
  <!-- Hero / token demo -->
  <EditorialSection
    eyebrow="PHASE 02 / TOKENS"
    headline="The Go-native agent framework for production."
    headlineFont="display"
    deck="Not a Python port. Not a prototype scaffold. Beluga is a complete 7-layer framework — streaming via iter.Seq2, OTel at every boundary, crash-durable execution, 110 providers."
    layout="split"
    cite={{ label: "docs/architecture/01-overview", href: "/docs/reference/architecture/overview/" }}
  >
    <CodeProof
      code={heroCode}
      lang="go"
      title="examples/stream-first-agent.go"
      caption="Streaming is the default, not a feature. Invoke() is the convenience wrapper around Stream() + collect."
      cite={{ label: "core/stream.go:49", href: "https://github.com/lookatitude/beluga-ai/blob/main/core/stream.go" }}
    />
  </EditorialSection>

  <!-- Proof pillar block -->
  <EditorialSection
    eyebrow="SHIP"
    headline="Production defaults, not production afterthoughts."
    deck="Every extensible package ships WithTracing() middleware, and circuit breakers are middleware on the same interface as your LLM call."
    bleed
    cite={{ label: "docs/architecture/15-resilience", href: "/docs/guides/production/resilience/" }}
  >
    <CodeProof
      code={middlewareCode}
      lang="go"
      caption="Four lines compose guardrails, tracing, rate limiting, and retry around the same Model instance."
      cite={{ label: "docs/architecture/03-extensibility-patterns.md §Ring 4", href: "/docs/concepts/extensibility/" }}
    />
  </EditorialSection>

  <!-- Pillar layout: split -->
  <EditorialSection
    eyebrow="110 PROVIDERS · 19 CATEGORIES"
    headline="One import. Fully wired."
    deck="LLM, embedding, vector stores, memory, voice, guard, workflow, observability. Every provider registers itself in init(). Import for side-effect, call llm.New — middleware, hooks, and metrics attach automatically."
    layout="split"
  >
    <CodeProof
      code={providerCode}
      lang="go"
      title="main.go"
    />
  </EditorialSection>

  <!-- Type scale sample -->
  <EditorialSection
    eyebrow="TYPOGRAPHY"
    headline="Fraunces · IBM Plex Sans · JetBrains Mono."
    deck="Editorial serif for display moments. IBM Plex Sans for body and UI — engineer-credible, OFL licensed, not Inter. JetBrains Mono for code and metadata marks."
  >
    <div class="type-grid">
      <div class="type-row">
        <span class="type-label">Display 72 / Fraunces</span>
        <span class="type-sample font-display" style="font-size: clamp(2.5rem, 5vw, 4.5rem); line-height: 1; letter-spacing: -0.035em;">
          Rigorous. Editorial. Unflinching.
        </span>
      </div>
      <div class="type-row">
        <span class="type-label">Heading 28 / Plex Sans 600</span>
        <span class="type-sample" style="font-size: 1.75rem; font-weight: 600; letter-spacing: -0.025em;">
          Every claim earns its pixels.
        </span>
      </div>
      <div class="type-row">
        <span class="type-label">Body 16 / Plex Sans 400</span>
        <p class="type-sample" style="max-width: 60ch; margin: 0;">
          The framework is built around ten architectural invariants. Every doc in this set cites real file:line references from the codebase — patterns link back to canonical implementations so nothing drifts from reality.
        </p>
      </div>
      <div class="type-row">
        <span class="type-label">Mono 13 / JetBrains 500</span>
        <span class="type-sample" style="font-family: var(--font-mono); font-size: 0.8125rem; letter-spacing: 0.02em;">
          core/stream.go:49 · Stream[T] backed by iter.Seq2
        </span>
      </div>
      <div class="type-row">
        <span class="type-label">Eyebrow / uppercase mono</span>
        <span class="eyebrow">SHIP · LAYER 02</span>
      </div>
    </div>
  </EditorialSection>

  <!-- Palette swatch -->
  <EditorialSection
    eyebrow="PALETTE"
    headline="Logo-anchored OKLCH."
    deck="Brand steel blue and pale aqua from the logo. Everything else is a tinted neutral — the page background is not gray, it's a deep cool near-black leaning into the brand hue."
  >
    <div class="swatches">
      <div class="swatch-group">
        <span class="swatch-group-label">BRAND</span>
        <div class="swatch-row">
          <div class="swatch" style="background: var(--brand-200);"><span>brand-200</span></div>
          <div class="swatch" style="background: var(--brand-300);"><span>brand-300</span></div>
          <div class="swatch" style="background: var(--brand-400);"><span>brand-400</span></div>
          <div class="swatch" style="background: var(--brand-500);"><span>brand-500 (logo)</span></div>
          <div class="swatch" style="background: var(--brand-600);"><span>brand-600</span></div>
          <div class="swatch" style="background: var(--brand-700);"><span>brand-700</span></div>
          <div class="swatch" style="background: var(--brand-800);"><span>brand-800</span></div>
        </div>
      </div>
      <div class="swatch-group">
        <span class="swatch-group-label">INK  · dark mode neutrals</span>
        <div class="swatch-row">
          <div class="swatch" style="background: var(--ink-950);"><span>ink-950 bg</span></div>
          <div class="swatch" style="background: var(--ink-900);"><span>ink-900</span></div>
          <div class="swatch" style="background: var(--ink-850);"><span>ink-850</span></div>
          <div class="swatch" style="background: var(--ink-800);"><span>ink-800 hair</span></div>
          <div class="swatch" style="background: var(--ink-700);"><span>ink-700</span></div>
          <div class="swatch" style="background: var(--ink-500);"><span>ink-500</span></div>
          <div class="swatch" style="background: var(--ink-300);"><span>ink-300 text</span></div>
          <div class="swatch" style="background: var(--ink-100);"><span>ink-100 head</span></div>
        </div>
      </div>
      <div class="swatch-group">
        <span class="swatch-group-label">PAPER · light mode neutrals</span>
        <div class="swatch-row">
          <div class="swatch" style="background: var(--paper-50); color: var(--paper-950);"><span>paper-50</span></div>
          <div class="swatch" style="background: var(--paper-100); color: var(--paper-950);"><span>paper-100</span></div>
          <div class="swatch" style="background: var(--paper-200); color: var(--paper-950);"><span>paper-200</span></div>
          <div class="swatch" style="background: var(--paper-300); color: var(--paper-950);"><span>paper-300</span></div>
          <div class="swatch" style="background: var(--paper-700); color: var(--paper-50);"><span>paper-700</span></div>
          <div class="swatch" style="background: var(--paper-900); color: var(--paper-50);"><span>paper-900</span></div>
          <div class="swatch" style="background: var(--paper-950); color: var(--paper-50);"><span>paper-950</span></div>
        </div>
      </div>
    </div>
  </EditorialSection>
</MarketingLayout>

<style>
  /* Type scale demo styles — scoped to this preview page only. */
  .type-grid {
    display: grid;
    gap: 2rem;
    max-width: 78rem;
  }

  .type-row {
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: 1.5rem;
    align-items: start;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--sl-color-hairline);
  }

  .type-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
    padding-top: 0.25rem;
  }

  .type-sample {
    color: var(--sl-color-white);
  }

  @media (max-width: 700px) {
    .type-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }

  /* Swatch grid */
  .swatches {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .swatch-group-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
    margin-bottom: 0.75rem;
  }

  .swatch-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
    gap: 0.5rem;
  }

  .swatch {
    aspect-ratio: 4 / 3;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.375rem;
    padding: 0.625rem 0.75rem;
    display: flex;
    align-items: flex-end;
    color: var(--ink-100);
  }
  .swatch span {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
</style>
