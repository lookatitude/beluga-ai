---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import EditorialSection from "@/components/marketing/EditorialSection.astro";
import CodeProof from "@/components/marketing/CodeProof.astro";
import LayerStack from "@/components/marketing/LayerStack.astro";

const heroCode = `import (
    _ "github.com/lookatitude/beluga-ai/llm/providers/anthropic"
    "github.com/lookatitude/beluga-ai/llm"
)

model, _ := llm.New("anthropic", llm.Config{Model: "claude-sonnet-4-6"})

stream, _ := model.Stream(ctx, []schema.Message{
    {Role: schema.RoleUser, Content: "explain iter.Seq2 in one sentence"},
})

for chunk, err := range stream.Range {
    if err != nil { break }
    fmt.Print(chunk.Content)
}`;

const middlewareCode = `base, _ := llm.New("anthropic", llm.Config{})

// Four lines compose guardrails, tracing, rate limiting, and retry
// around the same Model instance. Middleware is func(T) T — nothing
// more, nothing less.
model := llm.ApplyMiddleware(base,
    llm.WithGuardrails(guardPipeline),
    llm.WithTracing(),
    llm.WithRateLimit(rpm, tpm),
    llm.WithRetry(3),
)`;

const plannerCode = `// Swap reasoning strategies with one line.
// Eight planners share the same interface, from ReAct to LATS.
agent, _ := agent.New(ctx,
    agent.WithLLM(model),
    agent.WithPlanner("lats"),   // was "react"
    agent.WithTools(tools...),
)`;

const providerCode = `// 110 providers across 19 categories. Every provider
// registers itself in init(). Import for side-effect, and
// call <pkg>.New — middleware, hooks, and tracing attach.
import (
    _ "github.com/lookatitude/beluga-ai/llm/providers/anthropic"
    _ "github.com/lookatitude/beluga-ai/rag/vectorstore/providers/pgvector"
    _ "github.com/lookatitude/beluga-ai/voice/stt/providers/deepgram"
    _ "github.com/lookatitude/beluga-ai/workflow/providers/temporal"
)`;

const workflowCode = `import (
    "github.com/lookatitude/beluga-ai/workflow"
    _ "github.com/lookatitude/beluga-ai/workflow/providers/temporal"
)

store, _ := workflow.New("temporal", workflow.Config{
    Endpoint: "temporal:7233",
})

// Agents survive restarts. The workflow store replays from
// an event log — no application-level checkpointing.
wf, _ := store.Resume(ctx, runID)`;

const providerRows = [
  ["LLM", "22 providers", "anthropic · openai · bedrock · google · groq · cohere · mistral · deepseek · xai · openrouter · ollama · fireworks · together · perplexity · azure · cerebras · huggingface · qwen · llama · sambanova · bifrost · litellm"],
  ["Vector stores", "13 providers", "pgvector · pinecone · qdrant · weaviate · milvus · chroma · redis · elasticsearch · mongodb · vespa · turbopuffer · sqlitevec · inmemory"],
  ["Embedding", "9 providers", "openai · cohere · google · jina · voyage · mistral · sentence-transformers · ollama · inmemory"],
  ["Memory stores", "8 providers", "postgres · redis · mongodb · sqlite · dragonfly · neo4j · memgraph · inmemory"],
  ["Document loaders", "8 providers", "gdrive · github · notion · confluence · s3/gcs/azure · firecrawl · docling · unstructured"],
  ["STT · TTS · S2S", "16 providers", "deepgram · whisper · assemblyai · gladia · elevenlabs (stt+tts) · groq (stt+tts) · cartesia · fish · lmnt · playht · smallest · openai-realtime · gemini-live · amazon-nova"],
  ["Voice transport · VAD", "5 providers", "livekit · daily · pipecat · silero · webrtc"],
  ["Workflow engines", "6 providers", "temporal · inngest · dapr · kafka · nats · inmemory"],
  ["Guard", "5 providers", "lakera · llmguard · guardrailsai · nemo · azuresafety"],
  ["Observability exporters", "4 providers", "langfuse · langsmith · opik · phoenix"],
];

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: "Beluga AI",
      url: "https://beluga-ai.org",
      description: "The Go-native agent framework for production.",
    },
    {
      "@type": "SoftwareApplication",
      name: "Beluga AI",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Cross-platform",
      programmingLanguage: "Go",
      license: "https://opensource.org/licenses/MIT",
      url: "https://beluga-ai.org",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    },
  ],
});
---

<MarketingLayout
  title="Beluga AI"
  description="The Go-native agent framework for production. Streaming via iter.Seq2, OTel at every boundary, crash-durable execution, 110 providers."
  jsonLd={jsonLd}
>
  <!-- H1 · Hero with code visible in the first viewport -->
  <section class="hero" aria-label="Introduction">
    <div class="hero-frame">
      <div class="hero-lead">
        <span class="eyebrow hero-eyebrow">GO-NATIVE · v2 · MIT</span>
        <h1 class="hero-headline font-display">
          The Go-native agent framework for production.
        </h1>
        <p class="hero-deck">
          Not a Python port. Not a prototype scaffold. Beluga is a complete
          seven-layer framework — streaming via
          <code>iter.Seq2</code>, OpenTelemetry GenAI spans at every boundary,
          crash-durable execution, 110 providers.
        </p>
        <div class="hero-cta">
          <a href="/docs/start/quick-start/" class="btn btn-primary">
            Read the quickstart
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
          <a href="/docs/concepts/" class="btn btn-ghost">
            Browse the architecture →
          </a>
        </div>
      </div>
      <div class="hero-code">
        <CodeProof
          code={heroCode}
          lang="go"
          title="first_agent.go"
          cite={{ label: "core/stream.go — the Stream[T] type", href: "https://github.com/lookatitude/beluga-ai/blob/main/core/stream.go" }}
        />
      </div>
    </div>
  </section>

  <!-- H2 · The 7-layer stack -->
  <EditorialSection
    eyebrow="ARCHITECTURE"
    headline="Seven layers. One import path."
    headlineFont="display"
    deck="From Foundation primitives to your application code, each layer depends only on the layers below it. Downward arrows only. If you find an upward import, it's a bug."
    cite={{ label: "Read the concepts", href: "/docs/concepts/" }}
  >
    <LayerStack />
  </EditorialSection>

  <!-- H3 · Proof pillars -->
  <EditorialSection
    eyebrow="PROOF"
    headline="Built for the production side of Go."
    bleed
  >
    <div class="pillars">
      <article class="pillar pillar-a">
        <div class="pillar-meta"><span class="pillar-num">01</span><span class="pillar-tag">STREAMING</span></div>
        <h3 class="pillar-title"><code>iter.Seq2</code>, not channels.</h3>
        <p class="pillar-body">
          The streaming primitive is a typed range-over-func iterator.
          Backpressure is free. Goroutine leaks are impossible.
          <code>Invoke()</code> is the convenience wrapper around
          <code>Stream()</code> + collect — the stream path is the real contract.
        </p>
        <a class="pillar-cite" href="/docs/concepts/streaming/">
          Read how Stream[T] works →
        </a>
      </article>

      <article class="pillar pillar-b">
        <div class="pillar-meta"><span class="pillar-num">02</span><span class="pillar-tag">PLANNERS</span></div>
        <h3 class="pillar-title">Eight strategies, one interface.</h3>
        <p class="pillar-body">
          ReAct, Reflexion, Self-Discover, Mind-Map, Tree-of-Thought,
          Graph-of-Thought, LATS, Mixture-of-Agents — all implement the same
          <code>Planner</code> interface. Switching strategies is a one-line change.
          Build your own in the same slot.
        </p>
        <a class="pillar-cite" href="/docs/guides/capabilities/agents/">
          Swap planners in one line →
        </a>
      </article>

      <article class="pillar pillar-c">
        <div class="pillar-meta"><span class="pillar-num">03</span><span class="pillar-tag">OBSERVABILITY</span></div>
        <h3 class="pillar-title">OTel GenAI spans at every boundary.</h3>
        <p class="pillar-body">
          Seventeen extensible packages ship <code>WithTracing()</code> middleware
          that emits <code>gen_ai.*</code> spans. Works with Jaeger,
          Grafana Tempo, Honeycomb, Arize, and Langfuse out of the box.
          No custom instrumentation required.
        </p>
        <a class="pillar-cite" href="/docs/guides/production/observability/">
          Observability in production →
        </a>
      </article>

      <article class="pillar pillar-d">
        <div class="pillar-meta"><span class="pillar-num">04</span><span class="pillar-tag">DURABILITY</span></div>
        <h3 class="pillar-title">Crash-durable without checkpointing.</h3>
        <p class="pillar-body">
          The <code>workflow/</code> package replays from an event log.
          Temporal, Inngest, Dapr, NATS, Kafka — or in-process for tests.
          Agents survive process restarts without application-level checkpointing.
        </p>
        <a class="pillar-cite" href="/docs/guides/production/workflow-durability/">
          Workflow durability →
        </a>
      </article>
    </div>

    <div class="pillar-codes">
      <CodeProof
        code={middlewareCode}
        lang="go"
        caption="Resilience + observability compose as middleware on the same interface as your LLM call."
      />
      <CodeProof
        code={plannerCode}
        lang="go"
        caption="A planner swap is a config change. Every strategy implements the same interface."
      />
    </div>
  </EditorialSection>

  <!-- H4 · Provider breadth -->
  <EditorialSection
    eyebrow="110 PROVIDERS · 19 CATEGORIES"
    headline="One import. Fully wired."
    deck="Every provider registers itself in init(). Import for side-effect, call llm.New or vectorstore.New — middleware, hooks, and metrics attach without a line of wiring."
    layout="split"
    cite={{ label: "Browse the full catalog", href: "/providers/" }}
  >
    <CodeProof
      code={providerCode}
      lang="go"
      title="main.go"
    />

    <table class="provider-index">
      <thead>
        <tr>
          <th scope="col">Category</th>
          <th scope="col">Count</th>
          <th scope="col">Providers</th>
        </tr>
      </thead>
      <tbody>
        {providerRows.map(([cat, count, providers]) => (
          <tr>
            <th scope="row">{cat}</th>
            <td class="pi-count">{count}</td>
            <td class="pi-list">{providers}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </EditorialSection>

  <!-- H5 · Durability moment -->
  <EditorialSection
    eyebrow="CRASH-DURABLE"
    headline="Agents that survive restarts."
    deck="Durable workflows are a first-class concern, not a plugin. Replay from an event log so a redeploy, a pod restart, or a machine failure does not lose progress."
    layout="split"
    bleed
  >
    <CodeProof
      code={workflowCode}
      lang="go"
      title="workflow/resume.go"
      cite={{ label: "Workflow durability guide", href: "/docs/guides/production/workflow-durability/" }}
    />
  </EditorialSection>

  <!-- H6 · Final CTA -->
  <section class="final-cta">
    <div class="final-cta-frame">
      <h2 class="font-display">Start with the quickstart.</h2>
      <p>Build a streaming agent, wire a tool, read the architecture. No account required.</p>
      <div class="final-cta-actions">
        <a href="/docs/start/quick-start/" class="btn btn-primary">Read the quickstart</a>
        <a href="https://github.com/lookatitude/beluga-ai" class="btn btn-ghost" rel="noopener">Star on GitHub →</a>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  /* Hero layout — split, code visible in first viewport */
  .hero {
    padding-block: clamp(3.5rem, 7vw, 6rem) clamp(2rem, 5vw, 4rem);
  }

  .hero-frame {
    max-width: 76rem;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 4vw, 2.5rem);
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(2.5rem, 5vw, 4rem);
  }

  @media (min-width: 960px) {
    .hero-frame {
      grid-template-columns: minmax(0, 6fr) minmax(0, 7fr);
      align-items: start;
    }
  }

  .hero-lead {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero-eyebrow {
    color: var(--brand-300);
    margin-bottom: 0.25rem;
  }

  :global([data-theme="light"]) .hero-eyebrow {
    color: oklch(0.45 0.10 240);
  }

  .hero-headline {
    font-size: clamp(2.5rem, 5.6vw, 4.25rem);
    line-height: 1;
    letter-spacing: -0.035em;
    font-weight: 500;
    color: var(--sl-color-white);
    margin: 0.25rem 0 0;
    font-variation-settings: "opsz" 144, "SOFT" 30;
    max-width: 14ch;
  }

  .hero-deck {
    font-size: clamp(1.0625rem, 1.3vw, 1.1875rem);
    line-height: 1.55;
    color: var(--sl-color-gray-2);
    max-width: 54ch;
    margin: 0;
  }

  .hero-deck code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--sl-color-bg-inline-code);
    border: 1px solid var(--sl-color-hairline);
    padding: 0.08em 0.32em;
    border-radius: 0.2em;
    color: var(--sl-color-white);
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  /* Buttons (.btn / .btn-primary / .btn-ghost) live in components.css. */

  /* Pillars — staggered, not a grid */
  .pillars {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(2.5rem, 4vw, 3.5rem);
    margin-bottom: clamp(3rem, 6vw, 4rem);
  }

  @media (min-width: 800px) {
    .pillars {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      column-gap: clamp(3rem, 6vw, 5rem);
      row-gap: clamp(3.5rem, 6vw, 5rem);
    }
    .pillar-b { transform: translateY(3rem); }
    .pillar-d { transform: translateY(3rem); }
  }

  .pillar {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 32rem;
    border-left: 2px solid var(--brand-700);
    padding-left: 1.5rem;
  }

  .pillar-meta {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .pillar-num {
    color: var(--brand-300);
    font-weight: 500;
  }
  .pillar-tag {
    color: var(--sl-color-gray-3);
    font-weight: 500;
  }

  :global([data-theme="light"]) .pillar-num {
    color: oklch(0.42 0.11 240);
  }

  .pillar-title {
    font-family: var(--font-sans);
    font-size: clamp(1.25rem, 1.8vw, 1.4rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--sl-color-white);
    margin: 0;
  }
  .pillar-title code {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.92em;
    color: var(--brand-200);
  }

  .pillar-body {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--sl-color-gray-2);
    margin: 0;
  }
  .pillar-body code {
    font-family: var(--font-mono);
    font-size: 0.88em;
    color: var(--brand-200);
  }

  .pillar-cite {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--sl-color-gray-3);
    text-decoration: none;
    padding-top: 0.25rem;
    border-bottom: 1px solid transparent;
    width: fit-content;
    transition: color 0.15s ease, border-color 0.2s ease;
  }
  .pillar-cite:hover {
    color: var(--brand-200);
    border-bottom-color: var(--brand-200);
  }

  .pillar-codes {
    display: grid;
    gap: clamp(1.5rem, 3vw, 2rem);
    grid-template-columns: minmax(0, 1fr);
  }

  @media (min-width: 900px) {
    .pillar-codes {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    }
  }

  /* Provider index table */
  .provider-index {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    margin-top: 1.5rem;
  }

  .provider-index th,
  .provider-index td {
    text-align: left;
    padding: 0.75rem 0.75rem 0.75rem 0;
    vertical-align: top;
    border-bottom: 1px solid var(--sl-color-hairline);
  }
  .provider-index thead th {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
    padding-bottom: 0.5rem;
  }
  .provider-index tbody th {
    font-weight: 600;
    color: var(--sl-color-white);
    width: 11rem;
  }
  .pi-count {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--brand-300);
    white-space: nowrap;
    padding-right: 1.5rem !important;
    width: 8rem;
  }
  :global([data-theme="light"]) .pi-count {
    color: oklch(0.42 0.11 240);
  }
  .pi-list {
    color: var(--sl-color-gray-2);
    line-height: 1.55;
  }

  @media (max-width: 760px) {
    .provider-index,
    .provider-index thead,
    .provider-index tbody,
    .provider-index tr {
      display: block;
    }
    .provider-index thead { display: none; }
    .provider-index tbody th {
      width: auto;
      padding-top: 1rem;
    }
    .provider-index td {
      border: none;
      padding-block: 0.25rem;
    }
    .provider-index tr {
      border-bottom: 1px solid var(--sl-color-hairline);
      padding-bottom: 0.75rem;
    }
  }

  /* Final CTA */
  .final-cta {
    padding-block: clamp(5rem, 10vw, 8rem);
    border-top: 1px solid var(--sl-color-hairline);
  }
  .final-cta-frame {
    max-width: 52rem;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 4vw, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }
  .final-cta h2 {
    font-size: clamp(2rem, 4.2vw, 3.25rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    font-weight: 500;
    color: var(--sl-color-white);
    margin: 0;
    font-variation-settings: "opsz" 144, "SOFT" 30;
  }
  .final-cta p {
    font-size: 1.0625rem;
    color: var(--sl-color-gray-2);
    max-width: 44ch;
    margin: 0;
  }
  .final-cta-actions {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }
</style>
