---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import EditorialSection from "@/components/marketing/EditorialSection.astro";
import CodeProof from "@/components/marketing/CodeProof.astro";

const capabilities = [
  {
    label: "01",
    title: "Access control",
    desc: "Capability-based RBAC / ABAC, deny by default, per-tenant isolation via core.WithTenant(ctx). JWT validation at every HTTP handler and RPC endpoint.",
    pkg: "auth/",
    docHref: "/docs/reference/api/infrastructure/",
    docLabel: "auth package reference",
    icon: "key",
  },
  {
    label: "02",
    title: "Audit trail",
    desc: "Every agent turn, every tool call, every guard decision logged with run ID and tenant. Audit records are append-only and signed.",
    pkg: "audit/",
    docHref: "/docs/reference/api/infrastructure/",
    docLabel: "audit package reference",
    icon: "ledger",
  },
  {
    label: "03",
    title: "Cost tracking",
    desc: "Token counts, USD attribution, per-team quotas, per-request cost ceilings. Every LLM call emits a cost span. Dashboards and alerts wire to Grafana, Langfuse, or your own backend.",
    pkg: "cost/",
    docHref: "/docs/guides/production/observability/",
    docLabel: "cost + observability guide",
    icon: "gauge",
  },
  {
    label: "04",
    title: "Safety pipeline",
    desc: "Three-stage guard pipeline — Input, Output, Tool — with five guard providers: Lakera, LLM Guard, Guardrails AI, NeMo, Azure Content Safety. Prompt injection, PII detection, moderation, and capability sandboxing.",
    pkg: "guard/",
    docHref: "/docs/guides/production/safety-and-guards/",
    docLabel: "safety and guards guide",
    icon: "shield",
  },
  {
    label: "05",
    title: "Crash-durable execution",
    desc: "Agent runs survive process restarts. The workflow/ package replays from an event log. Temporal is a drop-in backend, plus Inngest, Dapr, NATS, Kafka, or in-process for tests.",
    pkg: "workflow/",
    docHref: "/docs/guides/production/workflow-durability/",
    docLabel: "workflow durability guide",
    icon: "clockwork",
  },
  {
    label: "06",
    title: "OTel GenAI observability",
    desc: "Seventeen packages emit gen_ai.* spans at every boundary. Four exporters shipped: Langfuse, LangSmith, Opik, Arize Phoenix. Works with any OTel-compatible backend.",
    pkg: "o11y/",
    docHref: "/docs/guides/production/observability/",
    docLabel: "observability guide",
    icon: "eye",
  },
];

const enterpriseCode = `// Production wiring — every enterprise concern is middleware
// on the same interface your dev team already knows.
base, _ := llm.New("anthropic", llm.Config{Model: "claude-sonnet-4-6"})

enterprise := llm.ApplyMiddleware(base,
    llm.WithAuth(auth.RequireTenant("finance")),
    llm.WithAudit(auditSink),
    llm.WithCostTracking(cost.PerTeam("ingest-team")),
    llm.WithGuardrails(guard.Pipeline(
        guard.Input("lakera"),
        guard.Output("llmguard"),
        guard.Tool("nemo"),
    )),
    llm.WithTracing(),
    llm.WithRetry(3),
)`;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Enterprise — Beluga AI",
  description: "Enterprise-grade operational concerns built into the framework, not bolted on.",
});
---

<MarketingLayout
  title="Enterprise"
  description="Access control, audit trails, cost tracking, safety pipeline, durable execution, and OTel observability — built into the framework."
  jsonLd={jsonLd}
>
  <!-- Intro -->
  <section class="page-intro">
    <div class="page-intro-frame">
      <span class="eyebrow">ENTERPRISE</span>
      <h1 class="page-headline">
        The concerns that aren't optional at scale.
      </h1>
      <p class="page-deck">
        Beluga is the same open-source framework you use for a prototype,
        plus six operational capabilities that become load-bearing the
        moment agents leave a single laptop. No separate paid edition.
        No feature-flagged fork. The code below is the code that ships.
      </p>
      <div class="ent-cta-top">
        <a href="#inquiry" class="btn btn-primary">File an enterprise inquiry</a>
        <a href="https://github.com/lookatitude/beluga-ai" class="btn btn-ghost" rel="noopener">View the repo →</a>
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <EditorialSection
    eyebrow="SIX CAPABILITIES"
    headline="Mapped to real packages."
    deck="Each capability below is a real Go package in the repo, not a roadmap bullet. The doc link points to the architecture document that explains how it fits the seven-layer model."
  >
    <div class="cap-grid">
      {capabilities.map((c) => (
        <article class="cap-row">
          <span class="cap-label">{c.label}</span>
          <div class="cap-icon" aria-hidden="true">
            {c.icon === "key" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="8" cy="14" r="4" />
                <path d="M11 11l9-9" />
                <path d="M16 6l3 3" />
              </svg>
            )}
            {c.icon === "ledger" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 4h11a2 2 0 012 2v14H7a2 2 0 01-2-2V4z" />
                <path d="M9 8h6M9 12h6M9 16h4" />
              </svg>
            )}
            {c.icon === "gauge" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 14a8 8 0 1116 0" />
                <path d="M12 14l4-4" />
                <circle cx="12" cy="14" r="1" fill="currentColor" />
              </svg>
            )}
            {c.icon === "shield" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3l8 3v6c0 4.5-3.5 8.5-8 9-4.5-.5-8-4.5-8-9V6l8-3z" />
                <path d="M9 12l2 2 4-4" />
              </svg>
            )}
            {c.icon === "clockwork" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9" />
                <path d="M12 7v5l3 2" />
                <path d="M3 12h2M19 12h2M12 3v2M12 19v2" />
              </svg>
            )}
            {c.icon === "eye" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 12s4-7 10-7 10 7 10 7-4 7-10 7-10-7-10-7z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            )}
          </div>
          <div class="cap-body">
            <h3 class="cap-title">{c.title}</h3>
            <p class="cap-desc">{c.desc}</p>
            <div class="cap-meta">
              <code class="cap-pkg">{c.pkg}</code>
              <a class="cap-doc" href={c.docHref}>{c.docLabel} →</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </EditorialSection>

  <!-- Code proof -->
  <EditorialSection
    eyebrow="WIRED TOGETHER"
    headline="One file. Six concerns."
    deck="All six capabilities compose as middleware on the same Model interface your developers already use for LLM calls in tests. Enterprise is a deployment configuration, not an architecture migration."
    layout="split"
    bleed
  >
    <CodeProof
      code={enterpriseCode}
      lang="go"
      title="production/llm.go"
      caption="Read outside-in: auth, audit, cost, guardrails, tracing, retry — every concern is a function application on the same interface."
      cite={{ label: "Extensibility — Ring 4 · Middleware", href: "/docs/concepts/extensibility/" }}
    />
  </EditorialSection>

  <!-- Scenario -->
  <EditorialSection
    eyebrow="THE SHAPE OF THE PROBLEM"
    headline="A platform team standardising agent tooling."
  >
    <div class="scenario">
      <p>
        A platform team at a fintech is consolidating agent tooling across
        40 services. They need a framework where every agent emits the same
        OTel spans, every LLM call is cost-attributed to a team, every tool
        call passes through the same guard pipeline, and no agent run
        silently drops state on a pod restart. They need audit logs that
        satisfy compliance review, not just developer debugging.
      </p>
      <p>
        They evaluate Beluga because it ships all six of those concerns as
        first-class packages — not because a vendor pitch deck promises them.
        Every claim on this page is verifiable by reading the file it
        references. If you are in a similar situation, the inquiry form
        below is the starting point.
      </p>
    </div>
  </EditorialSection>

  <!-- Inquiry -->
  <section id="inquiry" class="ent-inquiry">
    <div class="page-intro-frame">
      <span class="eyebrow">ENTERPRISE INQUIRY</span>
      <h2 class="font-display">What you get when you file.</h2>
      <p class="ent-inquiry-body">
        We do not have a sales team. Enterprise inquiries route to a
        GitHub issue template, reviewed by a core maintainer within three
        business days. We will schedule a one-hour architecture call, a
        deployment review, and — if it's a fit — roadmap alignment. No
        proposal decks, no procurement theatre.
      </p>

      <ul class="ent-ladder">
        <li>
          <span class="ent-ladder-step">01</span>
          <div>
            <strong>Architecture call — 60 min</strong>
            <span>We walk your team through the seven layers and map them to your constraints.</span>
          </div>
        </li>
        <li>
          <span class="ent-ladder-step">02</span>
          <div>
            <strong>Deployment review — 60 min</strong>
            <span>Docker / K8s / Temporal / embedded — we pick the right target for your ops profile.</span>
          </div>
        </li>
        <li>
          <span class="ent-ladder-step">03</span>
          <div>
            <strong>Roadmap alignment — ongoing</strong>
            <span>If your blockers are on the roadmap, we commit to a timeline. If they're not, we say so.</span>
          </div>
        </li>
      </ul>

      <div class="ent-inquiry-cta">
        <a
          href="https://github.com/lookatitude/beluga-ai/issues/new?template=enterprise-inquiry.md"
          class="btn btn-primary"
          rel="noopener"
        >
          File an enterprise inquiry on GitHub
        </a>
        <a href="/docs/concepts/" class="btn btn-ghost">Read the concepts first →</a>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  /* .page-intro / .page-intro-frame / .page-headline / .page-deck
     and .eyebrow live in components.css. */

  .ent-cta-top {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  /* Capability rows — not cards */
  .cap-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .cap-row {
    display: grid;
    grid-template-columns: 2.75rem 2.5rem 1fr;
    gap: 1.25rem;
    padding-block: 1.75rem;
    border-top: 1px solid var(--sl-color-hairline);
  }
  .cap-icon {
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    padding-top: 0.125rem;
    color: var(--brand-300);
    transition: color 0.15s ease;
  }
  :global([data-theme="light"]) .cap-icon {
    color: oklch(0.42 0.11 240);
  }
  .cap-row:hover .cap-icon {
    color: var(--brand-200);
  }
  @media (max-width: 640px) {
    .cap-row {
      grid-template-columns: 2.25rem 1fr;
      gap: 0.875rem;
    }
    .cap-icon {
      grid-column: 1 / 3;
      grid-row: 1;
      padding-top: 0;
    }
  }
  .cap-row:last-child {
    border-bottom: 1px solid var(--sl-color-hairline);
  }
  .cap-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--brand-300);
    padding-top: 0.25rem;
  }
  :global([data-theme="light"]) .cap-label {
    color: oklch(0.45 0.10 240);
  }

  .cap-title {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--sl-color-white);
    margin: 0 0 0.5rem;
  }
  .cap-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--sl-color-gray-2);
    margin: 0 0 0.75rem;
    max-width: 68ch;
  }
  .cap-meta {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    flex-wrap: wrap;
  }
  .cap-pkg {
    color: var(--brand-200);
    font-weight: 500;
    background: color-mix(in oklch, var(--brand-500) 10%, transparent);
    padding: 0.15em 0.4em;
    border-radius: 0.2em;
    border: 1px solid color-mix(in oklch, var(--brand-500) 24%, transparent);
  }
  .cap-doc {
    color: var(--sl-color-gray-3);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.2s ease;
  }
  .cap-doc:hover {
    color: var(--brand-200);
    border-bottom-color: var(--brand-200);
  }

  /* Scenario */
  .scenario {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(1.25rem, 3vw, 2.5rem);
  }
  @media (min-width: 900px) {
    .scenario { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  .scenario p {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--sl-color-gray-2);
    margin: 0;
  }

  /* Inquiry block */
  .ent-inquiry {
    padding-block: clamp(4rem, 9vw, 7rem);
    border-top: 1px solid var(--sl-color-hairline);
    background: var(--surface-1);
  }
  :global([data-theme="light"]) .ent-inquiry {
    background: color-mix(in oklch, var(--paper-100) 70%, var(--paper-50));
  }
  .ent-inquiry h2 {
    font-family: var(--font-sans);
    font-size: var(--text-h1);
    line-height: var(--lh-h1);
    letter-spacing: var(--track-h1);
    font-weight: 500;
    color: var(--sl-color-white);
    margin: 0.25rem 0 0;
    max-width: 18ch;
    text-wrap: balance;
  }
  .ent-inquiry-body {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--sl-color-gray-2);
    max-width: 64ch;
    margin: 0;
  }

  .ent-ladder {
    list-style: none;
    padding: 0;
    margin: 1rem 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 64ch;
  }
  .ent-ladder li {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: 1rem;
    padding: 0.875rem 1rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.375rem;
    background: color-mix(in oklch, var(--ink-950) 40%, transparent);
  }
  :global([data-theme="light"]) .ent-ladder li {
    background: var(--paper-50);
  }
  .ent-ladder-step {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--brand-300);
    padding-top: 0.15rem;
  }
  :global([data-theme="light"]) .ent-ladder-step {
    color: oklch(0.45 0.10 240);
  }
  .ent-ladder strong {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--sl-color-white);
    letter-spacing: -0.01em;
    margin-bottom: 0.25rem;
  }
  .ent-ladder span {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--sl-color-gray-2);
  }

  .ent-inquiry-cta {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  /* .btn / .btn-primary / .btn-ghost live in components.css */
</style>
