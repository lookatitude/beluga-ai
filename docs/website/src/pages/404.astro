---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
---

<MarketingLayout
  title="404 — Page not found"
  description="The page you were looking for isn't here. Head back to the quickstart, the concepts, or the provider catalog."
  robots="noindex, nofollow"
>
  <section class="nf">
    <div class="page-intro-frame">
      <span class="eyebrow">HTTP 404</span>
      <h1 class="page-headline">
        That path doesn't exist.
      </h1>
      <p class="page-deck">
        The page may have moved during the documentation reorganization, or
        the URL is misspelled. Try one of these — all load cleanly in both
        themes.
      </p>

      <ul class="nf-list">
        <li>
          <span class="nf-label">QUICKSTART</span>
          <a href="/docs/start/quick-start/">
            <strong>Build your first agent</strong>
            <span>Streaming via iter.Seq2 in under 30 lines.</span>
          </a>
        </li>
        <li>
          <span class="nf-label">CONCEPTS</span>
          <a href="/docs/concepts/">
            <strong>The 7-layer architecture</strong>
            <span>Core primitives, extensibility, streaming, errors, context.</span>
          </a>
        </li>
        <li>
          <span class="nf-label">PROVIDERS</span>
          <a href="/providers/">
            <strong>Browse 110 providers</strong>
            <span>LLM, vector store, voice, guard, workflow, observability.</span>
          </a>
        </li>
        <li>
          <span class="nf-label">PRODUCT</span>
          <a href="/product/">
            <strong>What Beluga can do</strong>
            <span>Build, Know, Ship — the three concerns of the agent stack.</span>
          </a>
        </li>
      </ul>

      <div class="nf-back">
        <a href="/" class="btn btn-primary">Back to the homepage →</a>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .nf {
    padding-block: clamp(6rem, 12vw, 10rem);
    min-height: calc(100vh - 12rem);
    display: flex;
    align-items: center;
  }
  /* .page-intro-frame / .page-headline / .page-deck / .eyebrow live
     in components.css. The .nf-* extras below cover the 404 list. */

  .nf-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: grid;
    gap: 0;
    border-top: 1px solid var(--sl-color-hairline);
  }
  .nf-list li {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--sl-color-hairline);
  }
  .nf-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--brand-300);
    padding-top: 0.2rem;
  }
  :root[data-theme="light"] .nf-label {
    color: oklch(0.45 0.10 240);
  }
  .nf-list a {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .nf-list strong {
    display: block;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--sl-color-white);
    letter-spacing: -0.01em;
    margin-bottom: 0.25rem;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
    width: fit-content;
  }
  .nf-list a:hover strong {
    border-bottom-color: var(--brand-300);
  }
  .nf-list span:not(.nf-label) {
    display: block;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--sl-color-gray-2);
  }

  .nf-back .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0.375rem;
    background: var(--brand-500);
    color: var(--ink-950);
    border: 1px solid var(--brand-500);
    transition: background 0.2s ease;
  }
  .nf-back .btn:hover {
    background: var(--brand-400);
  }
  :root[data-theme="light"] .nf-back .btn {
    background: oklch(0.42 0.11 240);
    border-color: oklch(0.42 0.11 240);
    color: var(--paper-50);
  }

  @media (max-width: 640px) {
    .nf-list li {
      grid-template-columns: 1fr;
      gap: 0.375rem;
    }
  }
</style>
