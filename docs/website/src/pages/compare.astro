---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import EditorialSection from "@/components/marketing/EditorialSection.astro";

type Cell = { value: string; note?: string };

type Row = {
  dimension: string;
  beluga: Cell;
  langchainGo: Cell;
  adkGo: Cell;
  eino: Cell;
  langchainPy: Cell;
};

const NA: Cell = { value: "not included", note: "not a built-in concern" };

const rows: Row[] = [
  {
    dimension: "Primary language",
    beluga: { value: "Go 1.23+" },
    langchainGo: { value: "Go" },
    adkGo: { value: "Go" },
    eino: { value: "Go" },
    langchainPy: { value: "Python" },
  },
  {
    dimension: "Streaming primitive",
    beluga: { value: "iter.Seq2[T, error]", note: "range-over-func, no channels" },
    langchainGo: { value: "channels" },
    adkGo: { value: "channels" },
    eino: { value: "channels" },
    langchainPy: { value: "async iterators" },
  },
  {
    dimension: "Reasoning strategies",
    beluga: { value: "8 built-in", note: "ReAct · Reflexion · Self-Discover · Mind-Map · ToT · GoT · LATS · MoA" },
    langchainGo: { value: "ReAct only" },
    adkGo: { value: "ReAct · Sequential" },
    eino: { value: "ReAct · Plan-and-Execute" },
    langchainPy: { value: "ReAct · many via LangGraph" },
  },
  {
    dimension: "Built-in OTel GenAI spans",
    beluga: { value: "17 packages", note: "gen_ai.* conventions, per-boundary" },
    langchainGo: { value: "not included" },
    adkGo: { value: "partial", note: "runtime spans only" },
    eino: { value: "partial" },
    langchainPy: { value: "community plugin", note: "not first-party" },
  },
  {
    dimension: "Durable workflow (built-in)",
    beluga: { value: "workflow/ + 6 backends", note: "temporal · inngest · dapr · nats · kafka · inmemory" },
    langchainGo: NA,
    adkGo: NA,
    eino: NA,
    langchainPy: { value: "LangGraph checkpointing", note: "Postgres / SQLite" },
  },
  {
    dimension: "Voice pipeline (built-in)",
    beluga: { value: "frame-based, 16+ providers", note: "STT · TTS · S2S · VAD · transport" },
    langchainGo: NA,
    adkGo: NA,
    eino: NA,
    langchainPy: NA,
  },
  {
    dimension: "Provider integrations",
    beluga: { value: "110 providers · 19 categories", note: "llm · embedding · vectorstore · voice · guard · workflow · observability" },
    langchainGo: { value: "~30", note: "mostly llm + vectorstore" },
    adkGo: { value: "~15" },
    eino: { value: "~40", note: "strong LLM coverage" },
    langchainPy: { value: "hundreds", note: "largest ecosystem" },
  },
  {
    dimension: "License",
    beluga: { value: "MIT" },
    langchainGo: { value: "MIT" },
    adkGo: { value: "Apache 2.0" },
    eino: { value: "Apache 2.0" },
    langchainPy: { value: "MIT" },
  },
];

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Compare — Beluga AI",
  description: "Honest comparison of Beluga with LangChain Go, Google ADK Go, Eino, and LangChain Python.",
});
---

<MarketingLayout
  title="Compare"
  description="How Beluga compares with LangChain Go, Google ADK Go, Eino, and LangChain Python — dimensions every Go engineer should check before adopting an agent framework."
  jsonLd={jsonLd}
>
  <!-- Intro -->
  <section class="cmp-intro">
    <div class="cmp-frame">
      <span class="eyebrow">COMPARE</span>
      <h1 class="cmp-headline font-display">
        An honest comparison.
      </h1>
      <p class="cmp-deck">
        Every cell below is verifiable — not a taste rating. Where a
        competitor has a genuine strength, it is acknowledged. Where a
        capability is missing, we say "not included" rather than a dash or
        a frown. Framework claims outside Beluga's own repo are
        <span class="cmp-flag">flagged for re-verification</span> before
        any decision — public docs drift fast.
      </p>
      <p class="cmp-meta">
        <span>Updated</span> 2026-04-12 ·
        <span>Beluga version</span> v2 ·
        <span>Source</span>
        <a href="https://github.com/lookatitude/beluga-ai/tree/main/docs">docs/</a>
      </p>
    </div>
  </section>

  <!-- Table -->
  <section class="cmp-table-section">
    <div class="cmp-frame cmp-frame-wide">
      <div class="cmp-scroll">
        <table class="cmp-table">
          <thead>
            <tr>
              <th scope="col" class="cmp-dim">Dimension</th>
              <th scope="col" class="cmp-beluga">
                <span class="cmp-brand">Beluga</span>
                <span class="cmp-sub">Go-native</span>
              </th>
              <th scope="col">
                <span class="cmp-name">LangChain Go</span>
                <span class="cmp-sub">tmc/langchaingo</span>
              </th>
              <th scope="col">
                <span class="cmp-name">Google ADK</span>
                <span class="cmp-sub">Go SDK</span>
              </th>
              <th scope="col">
                <span class="cmp-name">Eino</span>
                <span class="cmp-sub">cloudwego</span>
              </th>
              <th scope="col">
                <span class="cmp-name">LangChain</span>
                <span class="cmp-sub">Python</span>
              </th>
            </tr>
          </thead>
          <tbody>
            {rows.map((r) => (
              <tr>
                <th scope="row" class="cmp-dim">{r.dimension}</th>
                <td class="cmp-beluga">
                  <span class="cmp-val">{r.beluga.value}</span>
                  {r.beluga.note && <span class="cmp-note">{r.beluga.note}</span>}
                </td>
                <td>
                  <span class="cmp-val">{r.langchainGo.value}</span>
                  {r.langchainGo.note && <span class="cmp-note">{r.langchainGo.note}</span>}
                </td>
                <td>
                  <span class="cmp-val">{r.adkGo.value}</span>
                  {r.adkGo.note && <span class="cmp-note">{r.adkGo.note}</span>}
                </td>
                <td>
                  <span class="cmp-val">{r.eino.value}</span>
                  {r.eino.note && <span class="cmp-note">{r.eino.note}</span>}
                </td>
                <td>
                  <span class="cmp-val">{r.langchainPy.value}</span>
                  {r.langchainPy.note && <span class="cmp-note">{r.langchainPy.note}</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="cmp-footnote">
        Competitor cells reflect public documentation as of 2026-04-12.
        If you are about to make a production decision, verify against each
        project's current README before committing.
      </p>
    </div>
  </section>

  <!-- Closing narrative -->
  <EditorialSection
    eyebrow="THE HONEST ANSWER"
    headline="When Beluga is the right choice — and when it isn't."
    bleed
  >
    <div class="narrative">
      <div class="narrative-col">
        <h3>Beluga is the right choice when</h3>
        <ul>
          <li>Your team ships Go in production and does not want to debug Python interop.</li>
          <li>You need the full agent stack — LLM, RAG, voice, guards, observability, durability — in one consistent framework.</li>
          <li>You care about <code>iter.Seq2</code>, goroutine hygiene, and <code>context.Context</code> as first parameter.</li>
          <li>You run at a scale where OTel GenAI spans and cost attribution are not optional.</li>
          <li>You are building long-running agents that must survive pod restarts, and you do not want to bolt durability on after the fact.</li>
        </ul>
      </div>
      <div class="narrative-col">
        <h3>Beluga is not the right choice when</h3>
        <ul>
          <li>Your team is Python-native. LangChain Python's ecosystem is larger and mature here. Choose LangGraph.</li>
          <li>Your project depends on a specific LangChain plugin that has no equivalent in Go. Use the plugin.</li>
          <li>Your primary constraint is time-to-prototype rather than production operability. A Python notebook will get you there faster.</li>
          <li>You need a framework that is a thin wrapper — Beluga is opinionated. Those opinions are spelled out in <a href="/docs/concepts/">Concepts</a>. Disagree with them, choose something else.</li>
        </ul>
      </div>
    </div>
  </EditorialSection>

  <!-- CTA -->
  <section class="cmp-cta">
    <div class="cmp-frame">
      <h2 class="font-display">Still evaluating?</h2>
      <p>
        Read the architecture. Every claim in the table above traces back
        to a file in the repo.
      </p>
      <div class="cmp-actions">
        <a href="/docs/concepts/" class="btn btn-primary">Read the concepts</a>
        <a href="/product/" class="btn btn-ghost">Back to the product →</a>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .cmp-intro {
    padding-block: clamp(5rem, 11vw, 8.5rem) clamp(2.5rem, 5vw, 3.5rem);
  }
  .cmp-frame {
    max-width: 58rem;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 4vw, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .cmp-frame-wide {
    max-width: 80rem;
  }

  .cmp-intro .eyebrow {
    color: var(--brand-300);
  }
  :global([data-theme="light"]) .cmp-intro .eyebrow {
    color: oklch(0.45 0.10 240);
  }

  .cmp-headline {
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.035em;
    font-weight: 500;
    color: var(--sl-color-white);
    margin: 0.5rem 0 0;
    font-variation-settings: "opsz" 144, "SOFT" 30;
  }

  .cmp-deck {
    font-size: clamp(1.0625rem, 1.3vw, 1.1875rem);
    line-height: 1.6;
    color: var(--sl-color-gray-2);
    max-width: 60ch;
    margin: 0;
  }

  .cmp-flag {
    color: var(--brand-200);
    font-weight: 500;
    white-space: nowrap;
  }
  :global([data-theme="light"]) .cmp-flag {
    color: oklch(0.42 0.11 240);
  }

  .cmp-meta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--sl-color-gray-3);
    margin-top: 0.25rem;
  }
  .cmp-meta span {
    text-transform: uppercase;
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    color: var(--sl-color-gray-4);
    margin-right: 0.375rem;
  }
  .cmp-meta a {
    color: var(--brand-300);
    text-decoration: none;
  }
  .cmp-meta a:hover {
    color: var(--brand-200);
  }

  /* Table */
  .cmp-table-section {
    padding-block: clamp(1rem, 3vw, 2rem) clamp(3rem, 6vw, 5rem);
  }

  .cmp-scroll {
    overflow-x: auto;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    background: color-mix(in oklch, var(--ink-900) 85%, var(--ink-950));
  }
  :global([data-theme="light"]) .cmp-scroll {
    background: var(--paper-100);
  }

  .cmp-table {
    width: 100%;
    min-width: 60rem;
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: 0.875rem;
  }

  .cmp-table th,
  .cmp-table td {
    padding: 1rem 1.125rem;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--sl-color-hairline);
  }

  .cmp-table thead th {
    background: color-mix(in oklch, var(--ink-950) 40%, transparent);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--sl-color-gray-2);
  }

  :global([data-theme="light"]) .cmp-table thead th {
    background: color-mix(in oklch, var(--paper-200) 50%, transparent);
  }

  .cmp-table thead th.cmp-beluga {
    background: color-mix(in oklch, var(--brand-700) 22%, var(--ink-950));
    color: var(--sl-color-white);
  }
  :global([data-theme="light"]) .cmp-table thead th.cmp-beluga {
    background: color-mix(in oklch, var(--brand-500) 14%, var(--paper-100));
  }

  .cmp-brand {
    display: block;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--brand-200);
    margin-bottom: 0.125rem;
  }
  :global([data-theme="light"]) .cmp-brand {
    color: oklch(0.42 0.11 240);
  }

  .cmp-name {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--sl-color-white);
    text-transform: none;
    letter-spacing: -0.01em;
    margin-bottom: 0.125rem;
  }

  .cmp-sub {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 400;
    color: var(--sl-color-gray-3);
    letter-spacing: 0.02em;
    text-transform: none;
  }

  .cmp-table tbody th.cmp-dim {
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--sl-color-white);
    width: 11rem;
    letter-spacing: -0.005em;
  }

  .cmp-table td.cmp-beluga {
    background: color-mix(in oklch, var(--brand-700) 12%, var(--ink-950));
    border-left: 1px solid var(--sl-color-hairline);
    border-right: 1px solid var(--sl-color-hairline);
  }
  :global([data-theme="light"]) .cmp-table td.cmp-beluga {
    background: color-mix(in oklch, var(--brand-500) 7%, var(--paper-100));
  }

  .cmp-val {
    display: block;
    color: var(--sl-color-white);
    font-weight: 500;
  }

  .cmp-note {
    display: block;
    margin-top: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
    line-height: 1.45;
  }

  .cmp-footnote {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.55;
    color: var(--sl-color-gray-3);
    margin-top: 1rem;
    max-width: 64ch;
  }

  /* Narrative columns */
  .narrative {
    display: grid;
    gap: clamp(2rem, 4vw, 3rem);
  }
  @media (min-width: 800px) {
    .narrative {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    }
  }
  .narrative-col h3 {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--sl-color-white);
    margin: 0 0 0.75rem;
  }
  .narrative-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .narrative-col li {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--sl-color-gray-2);
    padding-left: 1rem;
    border-left: 2px solid var(--sl-color-hairline);
  }
  .narrative-col li code {
    font-family: var(--font-mono);
    font-size: 0.88em;
    color: var(--brand-200);
  }
  .narrative-col li a {
    color: var(--brand-300);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }

  /* CTA */
  .cmp-cta {
    padding-block: clamp(4rem, 9vw, 7rem);
    border-top: 1px solid var(--sl-color-hairline);
  }
  .cmp-cta .cmp-frame {
    align-items: flex-start;
  }
  .cmp-cta h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    font-weight: 500;
    color: var(--sl-color-white);
    margin: 0;
    font-variation-settings: "opsz" 144, "SOFT" 30;
  }
  .cmp-cta p {
    font-size: 1.0625rem;
    color: var(--sl-color-gray-2);
    max-width: 48ch;
    margin: 0;
  }
  .cmp-actions {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    border-radius: 0.375rem;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .btn-primary {
    background: var(--brand-500);
    color: var(--ink-950);
    font-weight: 600;
  }
  .btn-primary:hover { background: var(--brand-400); }
  :global([data-theme="light"]) .btn-primary {
    background: oklch(0.42 0.11 240);
    color: var(--paper-50);
  }
  .btn-ghost {
    color: var(--sl-color-gray-2);
    padding-inline: 0.25rem;
  }
  .btn-ghost:hover { color: var(--brand-300); }
</style>
