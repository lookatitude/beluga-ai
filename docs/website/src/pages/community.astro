---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import EditorialSection from "@/components/marketing/EditorialSection.astro";

const channels = [
  {
    name: "GitHub",
    url: "https://github.com/lookatitude/beluga-ai",
    desc: "Source, issues, discussions, releases. File bugs, read the code, send PRs.",
    meta: "github.com/lookatitude/beluga-ai",
  },
  {
    name: "GitHub Discussions",
    url: "https://github.com/lookatitude/beluga-ai/discussions",
    desc: "Roadmap input, feature RFCs, async Q&A. The primary long-form channel.",
    meta: "long-form, public, searchable",
  },
  {
    name: "Discord",
    url: "https://github.com/lookatitude/beluga-ai/discussions",
    desc: "Real-time chat, show-and-tell, release announcements. Link published at v2 launch.",
    meta: "coming with v2 launch",
  },
  {
    name: "Blog",
    url: "#",
    desc: "Release notes, architecture deep-dives, migration notes. First post ships with v2.",
    meta: "coming soon",
  },
];

const roadmapPhases = [
  { phase: "01", label: "Foundation", status: "complete", desc: "core · schema · config · o11y · resilience · streaming via iter.Seq2" },
  { phase: "02", label: "Capabilities", status: "complete", desc: "llm · tool · memory · rag · voice · guard · prompt · cache" },
  { phase: "03", label: "Runtime", status: "complete", desc: "agent · runtime · orchestration · protocol (MCP / A2A / REST / gRPC / WS)" },
  { phase: "04", label: "Production", status: "complete", desc: "workflow durability · audit · cost · auth · eval · HITL · enterprise observability" },
  { phase: "05", label: "Next", status: "in progress", desc: "stability hardening, expanded provider catalog, documentation pass — shaped by Discussions" },
];

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Community — Beluga AI",
  description: "Open source · MIT licensed · built in Go. How to participate and where to find us.",
});
---

<MarketingLayout
  title="Community"
  description="Beluga AI is open source under MIT, built in Go, maintained in the open. Join Discussions, file issues, send PRs."
  jsonLd={jsonLd}
>
  <!-- Intro -->
  <section class="com-intro">
    <div class="com-frame">
      <span class="eyebrow">COMMUNITY</span>
      <h1 class="com-headline font-display">
        Built in the open. Moved by the people who use it.
      </h1>
      <p class="com-deck">
        Go teams building AI products face a real choice: Python interop,
        fragile bindings, or incomplete libraries. Beluga is the answer
        built entirely in Go — testable, deployable, reasoned about with
        standard Go tooling. MIT licensed. The roadmap is public.
        The issues are public. The code review is public.
      </p>
    </div>
  </section>

  <!-- Why Go -->
  <EditorialSection
    eyebrow="WHY GO"
    headline="Three reasons, no manifesto."
  >
    <div class="why-grid">
      <div class="why-col">
        <span class="why-num">01</span>
        <h3>Deterministic concurrency</h3>
        <p>
          <code>context.Context</code> is the cancellation, tracing, tenant,
          and auth story in one primitive. Goroutines are cheap but bounded
          by worker pools, not sprayed on hope.
        </p>
      </div>
      <div class="why-col">
        <span class="why-num">02</span>
        <h3>Single-binary deployment</h3>
        <p>
          Ship one binary to production. No Python venv, no node_modules,
          no wheel compilation on the target. Docker images are tens of
          megabytes, not gigabytes.
        </p>
      </div>
      <div class="why-col">
        <span class="why-num">03</span>
        <h3>Compile-time safety</h3>
        <p>
          Generics carry types through the <code>Stream[T]</code> pipeline.
          <code>interface{}</code> never appears in public APIs.
          Refactoring agents is a type-checked operation, not a grep.
        </p>
      </div>
    </div>
  </EditorialSection>

  <!-- Channels -->
  <EditorialSection
    eyebrow="CHANNELS"
    headline="Where to find the project."
    deck="Public by default. No paid tiers, no gated Slack, no NDA-only channels."
    bleed
  >
    <div class="channel-list">
      {channels.map((c) => (
        <a href={c.url} class="channel" rel="noopener">
          <div class="channel-head">
            <span class="channel-name">{c.name}</span>
            <span class="channel-meta">{c.meta}</span>
          </div>
          <p class="channel-desc">{c.desc}</p>
          <span class="channel-arrow">→</span>
        </a>
      ))}
    </div>
  </EditorialSection>

  <!-- Contributor ladder -->
  <EditorialSection
    eyebrow="CONTRIBUTING"
    headline="The ladder is short."
  >
    <div class="contrib">
      <ol>
        <li>
          <strong>File a good first issue.</strong>
          <span>Issues tagged <code>good-first-issue</code> are small, self-contained, and reviewed within 48 hours.</span>
        </li>
        <li>
          <strong>Read the architecture.</strong>
          <span>The seven-layer model and the four extensibility rings are the entire mental model — see <a href="/docs/concepts/">Concepts</a>.</span>
        </li>
        <li>
          <strong>Send a PR.</strong>
          <span>Red/Green TDD, table-driven tests, <code>go vet ./...</code>, <code>gosec</code>, <code>govulncheck</code> pass locally. CI runs the same plus Snyk, Trivy, CodeQL, SonarCloud.</span>
        </li>
        <li>
          <strong>Become a maintainer.</strong>
          <span>A sustained record of merged PRs, thoughtful reviews, and Discussions participation. We name maintainers in public.</span>
        </li>
      </ol>
      <a class="contrib-link" href="/docs/contributing/">
        Read the contributing guide →
      </a>
    </div>
  </EditorialSection>

  <!-- Roadmap -->
  <EditorialSection
    eyebrow="ROADMAP"
    headline="Four phases shipped. One in progress."
    bleed
  >
    <div class="roadmap">
      {roadmapPhases.map((p) => (
        <div class={`phase phase-${p.status === "complete" ? "done" : "now"}`}>
          <div class="phase-head">
            <span class="phase-num">{p.phase}</span>
            <span class="phase-label">{p.label}</span>
            <span class="phase-status">{p.status}</span>
          </div>
          <p class="phase-desc">{p.desc}</p>
        </div>
      ))}
    </div>
    <p class="roadmap-note">
      Shape phase 05 in <a href="https://github.com/lookatitude/beluga-ai/discussions">GitHub Discussions</a>.
      No promise grid — only merged milestones.
    </p>
  </EditorialSection>

  <!-- License -->
  <section class="com-license">
    <div class="com-frame">
      <h2 class="font-display">MIT. That's it.</h2>
      <p>
        Use Beluga in a closed-source product. Fork it. Rewrite it. We ask
        that you contribute improvements back so the next person who hits
        the same edge case does not have to rediscover the solution —
        but we will not force you.
      </p>
      <a class="com-license-link" href="https://github.com/lookatitude/beluga-ai/blob/main/LICENSE">
        Read the license →
      </a>
    </div>
  </section>
</MarketingLayout>

<style>
  .com-intro {
    padding-block: clamp(5rem, 11vw, 8.5rem) clamp(2.5rem, 5vw, 3.5rem);
  }
  .com-frame {
    max-width: 58rem;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 4vw, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .com-intro .eyebrow {
    color: var(--brand-300);
  }
  :global([data-theme="light"]) .com-intro .eyebrow {
    color: oklch(0.45 0.10 240);
  }
  .com-headline {
    font-size: clamp(2.25rem, 5vw, 4rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    font-weight: 500;
    color: var(--sl-color-white);
    margin: 0.5rem 0 0;
    max-width: 18ch;
    font-variation-settings: "opsz" 144, "SOFT" 30;
  }
  .com-deck {
    font-size: clamp(1.0625rem, 1.3vw, 1.1875rem);
    line-height: 1.6;
    color: var(--sl-color-gray-2);
    max-width: 60ch;
    margin: 0;
  }

  /* Why Go columns */
  .why-grid {
    display: grid;
    gap: clamp(2rem, 4vw, 3rem);
    max-width: 76rem;
  }
  @media (min-width: 760px) {
    .why-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  .why-col {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    border-top: 1px solid var(--sl-color-hairline);
    padding-top: 1.25rem;
  }
  .why-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--brand-300);
  }
  :global([data-theme="light"]) .why-num {
    color: oklch(0.45 0.10 240);
  }
  .why-col h3 {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--sl-color-white);
    margin: 0;
  }
  .why-col p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--sl-color-gray-2);
    margin: 0;
  }
  .why-col p code {
    font-family: var(--font-mono);
    font-size: 0.88em;
    color: var(--brand-200);
  }

  /* Channel cards — not grid of icons */
  .channel-list {
    display: grid;
    gap: 1rem;
    max-width: 76rem;
  }
  @media (min-width: 760px) {
    .channel-list { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  .channel {
    position: relative;
    display: block;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    background: color-mix(in oklch, var(--ink-950) 60%, transparent);
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .channel:hover {
    border-color: color-mix(in oklch, var(--brand-500) 40%, var(--sl-color-hairline));
    background: color-mix(in oklch, var(--ink-900) 50%, var(--ink-950));
  }
  :global([data-theme="light"]) .channel {
    background: var(--paper-50);
  }
  :global([data-theme="light"]) .channel:hover {
    background: var(--paper-100);
  }
  .channel-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  .channel-name {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--sl-color-white);
  }
  .channel-meta {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
  }
  .channel-desc {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--sl-color-gray-2);
    margin: 0;
    max-width: 54ch;
  }
  .channel-arrow {
    position: absolute;
    right: 1.5rem;
    top: 1.25rem;
    color: var(--sl-color-gray-3);
    font-family: var(--font-mono);
    transition: transform 0.2s ease, color 0.15s ease;
  }
  .channel:hover .channel-arrow {
    transform: translateX(3px);
    color: var(--brand-300);
  }

  /* Contributor ladder */
  .contrib {
    max-width: 64ch;
  }
  .contrib ol {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    counter-reset: step;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .contrib li {
    position: relative;
    padding: 0.875rem 0 0.875rem 2.5rem;
    border-top: 1px solid var(--sl-color-hairline);
    counter-increment: step;
  }
  .contrib li:last-child {
    border-bottom: 1px solid var(--sl-color-hairline);
  }
  .contrib li::before {
    content: counter(step, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 0.875rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--brand-300);
  }
  :global([data-theme="light"]) .contrib li::before {
    color: oklch(0.45 0.10 240);
  }
  .contrib strong {
    display: block;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    color: var(--sl-color-white);
    letter-spacing: -0.01em;
    margin-bottom: 0.25rem;
  }
  .contrib span {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--sl-color-gray-2);
  }
  .contrib code {
    font-family: var(--font-mono);
    font-size: 0.88em;
    color: var(--brand-200);
    padding: 0.05em 0.25em;
    background: color-mix(in oklch, var(--brand-500) 10%, transparent);
    border-radius: 0.2em;
  }
  .contrib a {
    color: var(--brand-300);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }
  .contrib-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--sl-color-gray-3);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.2s ease;
  }
  .contrib-link:hover {
    color: var(--brand-200);
    border-bottom-color: var(--brand-200);
  }

  /* Roadmap */
  .roadmap {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 68rem;
  }
  .phase {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: 1.5rem;
    padding-block: 1.25rem;
    border-top: 1px solid var(--sl-color-hairline);
  }
  .phase:last-child {
    border-bottom: 1px solid var(--sl-color-hairline);
  }
  .phase-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--sl-color-gray-3);
  }
  .phase-head {
    display: flex;
    align-items: baseline;
    gap: 0.875rem;
    flex-wrap: wrap;
  }
  .phase-label {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--sl-color-white);
  }
  .phase-status {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.15em 0.5em;
    border-radius: 0.2em;
  }
  .phase-done .phase-status {
    color: var(--brand-300);
    background: color-mix(in oklch, var(--brand-500) 14%, transparent);
    border: 1px solid color-mix(in oklch, var(--brand-500) 30%, transparent);
  }
  .phase-now .phase-status {
    color: var(--ink-100);
    background: color-mix(in oklch, var(--brand-600) 25%, transparent);
    border: 1px solid color-mix(in oklch, var(--brand-500) 50%, transparent);
  }
  :global([data-theme="light"]) .phase-done .phase-status {
    color: oklch(0.40 0.11 240);
  }
  .phase-desc {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--sl-color-gray-2);
    margin: 0.375rem 0 0;
    grid-column: 2;
  }
  .phase > .phase-head { grid-column: 2; }
  .phase > .phase-num { grid-column: 1; grid-row: 1 / 3; padding-top: 0.125rem; }

  .roadmap-note {
    margin-top: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--sl-color-gray-3);
    max-width: 64ch;
  }
  .roadmap-note a {
    color: var(--brand-300);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }

  /* License */
  .com-license {
    padding-block: clamp(4rem, 9vw, 7rem);
    border-top: 1px solid var(--sl-color-hairline);
  }
  .com-license h2 {
    font-size: clamp(2rem, 4.2vw, 3.25rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    font-weight: 500;
    color: var(--sl-color-white);
    margin: 0;
    font-variation-settings: "opsz" 144, "SOFT" 30;
  }
  .com-license p {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--sl-color-gray-2);
    max-width: 62ch;
    margin: 0;
  }
  .com-license-link {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--brand-300);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.2s ease;
    width: fit-content;
    margin-top: 0.5rem;
  }
  .com-license-link:hover {
    color: var(--brand-200);
    border-bottom-color: var(--brand-200);
  }
</style>
